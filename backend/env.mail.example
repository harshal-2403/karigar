# Copy values into your environment (PowerShell: $env:KARIGAR_MAIL_FROM="..." )
# Gmail: use an App Password — https://support.google.com/accounts/answer/185833
# The "From" address must be the same Google account that owns the App Password.

KARIGAR_MAIL_FROM=your.app@gmail.com
KARIGAR_MAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional (defaults shown)
# KARIGAR_SMTP_HOST=smtp.gmail.com
# KARIGAR_SMTP_PORT=587

# Local dev without sending mail: prints OTP to the server console
# KARIGAR_MAIL_LOG_OTP=true
