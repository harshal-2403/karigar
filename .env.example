# Backend API (Java servlets), e.g. http://localhost:8080/karigar-backend
VITE_API_URL=http://localhost:8080/karigar-backend

# Auth0 SPA — from Auth0 Dashboard → Applications → Your app
# Use the same "Allowed Callback URLs" and "Allowed Logout URLs" as your app origin (e.g. http://localhost:5173/)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=yourClientId

# Do NOT put the client secret in Vite env files — it is not used in the browser.
# Keep the secret only for server-side or M2M apps.

# --- Backend (Jetty/Tomcat) — must match the SPA tenant and Application Client ID for /api/auth/sync JWT checks
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=yourClientId
